{
  "project": {
    "name": "Agent Registry Kanban",
    "id": "blackroad-agent-registry",
    "version": "1.0.0",
    "created": "2026-01-27",
    "owner": "BlackRoad-OS",
    "description": "Kanban project management for AI agent orchestration with CRM state sync"
  },
  "boards": {
    "main": {
      "id": "main-board",
      "name": "Agent Operations",
      "columns": [
        {
          "id": "backlog",
          "name": "Backlog",
          "limit": null,
          "color": "#6B7280"
        },
        {
          "id": "todo",
          "name": "To Do",
          "limit": 20,
          "color": "#3B82F6"
        },
        {
          "id": "in-progress",
          "name": "In Progress",
          "limit": 10,
          "color": "#F59E0B"
        },
        {
          "id": "review",
          "name": "Review",
          "limit": 5,
          "color": "#8B5CF6"
        },
        {
          "id": "done",
          "name": "Done",
          "limit": null,
          "color": "#10B981"
        }
      ]
    },
    "agents": {
      "id": "agent-board",
      "name": "Agent Assignments",
      "columns": [
        {
          "id": "available",
          "name": "Available Agents",
          "limit": null
        },
        {
          "id": "assigned",
          "name": "Assigned",
          "limit": 100
        },
        {
          "id": "working",
          "name": "Working",
          "limit": 50
        },
        {
          "id": "completed",
          "name": "Completed Tasks",
          "limit": null
        }
      ]
    }
  },
  "workflows": {
    "pr_lifecycle": {
      "stages": ["draft", "ready", "review", "approved", "merged"],
      "validation_required": true,
      "auto_assign_agents": true
    },
    "task_lifecycle": {
      "stages": ["created", "assigned", "started", "completed", "verified"],
      "require_hash_verification": true
    }
  },
  "sync": {
    "salesforce": {
      "enabled": true,
      "object_mapping": {
        "task": "Task__c",
        "agent": "Agent__c",
        "project": "Project__c"
      },
      "sync_interval": 300
    },
    "cloudflare": {
      "enabled": true,
      "kv_namespace": "AGENT_REGISTRY_STATE",
      "workers_enabled": true
    },
    "github": {
      "enabled": true,
      "projects_enabled": true,
      "issues_sync": true,
      "pr_sync": true
    }
  },
  "agents": {
    "auto_assignment": {
      "enabled": true,
      "match_by": ["type", "capabilities", "availability"],
      "load_balancing": "round_robin"
    },
    "registry_source": "./agents.json",
    "type_index": "./agents-by-type.json"
  }
}
